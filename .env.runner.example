# AI-ASSISTED: Cursor
# PROMPT: Example env for deployed TestUI runner + git artifact sync
# ACCEPTED-BY: vignesh

# Server
HOST=0.0.0.0
PORT=4173

# After each suite run, commit automation/runs into the git checkout
RUNNER_GIT_SYNC=true
# Push the commit to the remote (requires credentials on the host)
RUNNER_GIT_PUSH=true
RUNNER_GIT_REMOTE=origin
# Leave empty to use the current checked-out branch
RUNNER_GIT_BRANCH=
# Optional metadata shown in the Test Runner UI
RUNNER_GIT_REPO_URL=https://version.onebill.net/onebill/QE_Engine.git
RUNNER_GIT_USER_NAME=TestUi Runner
RUNNER_GIT_USER_EMAIL=testui-runner@onebill.local
