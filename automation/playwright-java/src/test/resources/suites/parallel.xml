<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TestUi-Playwright-Parallel" parallel="methods" thread-count="3" verbose="1" data-provider-thread-count="2">
    <listeners>
        <listener class-name="com.testui.playwright.listeners.TestListener"/>
    </listeners>
    <parameter name="baseUrl" value="http://localhost:5173"/>
    <parameter name="browser" value="chrome"/>
    <parameter name="headless" value="true"/>
    <test name="ParallelSmoke">
        <classes>
            <class name="com.testui.playwright.tests.LoginTest">
                <methods>
                    <include name="adminLoginSuccess"/>
                    <include name="fillDemoAdminChip"/>
                </methods>
            </class>
            <class name="com.testui.playwright.tests.DashboardTest"/>
            <class name="com.testui.playwright.tests.UsersTest">
                <methods>
                    <include name="navigateToUsers"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
