<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TestUi-Playwright-Regression" verbose="1">
    <listeners>
        <listener class-name="com.testui.playwright.listeners.TestListener"/>
    </listeners>
    <parameter name="baseUrl" value="http://localhost:5173"/>
    <parameter name="browser" value="chrome"/>
    <test name="Regression">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.testui.playwright.tests"/>
        </packages>
    </test>
</suite>
