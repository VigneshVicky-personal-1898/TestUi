<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TestUi-users-Negative" verbose="1">
    <listeners>
        <listener class-name="com.testui.selenium.listeners.TestListener"/>
    </listeners>
    <parameter name="baseUrl" value="http://localhost:5173"/>
    <parameter name="browser" value="chrome"/>
    <test name="Negative">
        <parameter name="email" value="admin@gmail.com"/>
        <parameter name="password" value="admin@123"/>
        <parameter name="captcha" value="TEST"/>
        <parameter name="userName" value="Temp User"/>
        <parameter name="userEmail" value="temp@testui.com"/>
        <parameter name="userDepartment" value="QA"/>
        <parameter name="userPhone" value="555-0000"/>
        <classes>
            <class name="com.testui.selenium.tests.UsersTest">
                <methods>
                    <include name="cancelAddUserLeavesTableUnchanged"/>
                </methods>
            </class>
        </classes>
    </test>
</suite>
